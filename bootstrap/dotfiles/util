#!/bin/bash
# shellcheck disable=SC2034

# ----------------------------------------
# Al's Utility Functions
# ----------------------------------------

# Bash colors
black=$'\e[0;30m'
red=$'\e[0;31m'
green=$'\e[0;32m'
yellow=$'\e[0;33m'
blue=$'\e[0;34m'
purple=$'\e[0;35m'
cyan=$'\e[0;36m'
white=$'\e[0;37m'
end=$'\e[0m'

# Standard coloring for scripts
echo_error() { echo -e "${red}[ERROR]${end} ${1}"; }
echo_warn() { echo -e "${yellow}[WARN]${end} ${1}"; }
echo_ok() { echo -e "${green}[OK]${end} ${1}"; }
echo_info() { echo -e "${blue}[INFO]${end} ${1}"; }

# Source a dotfile if it exists
source_dotfile() {
  if test -f "${HOME}/${1}"; then
    # shellcheck disable=SC1090
    source "${HOME}/${1}"
  fi
}

# Setup SSH Agent (for not needing to input passwords every time)
setup_ssh_agent() {
  if ! command -v ssh-agent &>/dev/null; then
    return
  fi

  if [ ! -f "$HOME/.ssh/id_rsa" ] && [ ! -f "$HOME/.ssh/id_ed25519" ]; then
    return
  fi

  # Check if agent is already running
  if [ -n "${SSH_AGENT_PID}" ]; then
    if ps -p "${SSH_AGENT_PID}" &>/dev/null; then
      return
    fi
    unset SSH_AGENT_PID
    unset SSH_AUTH_SOCK
  fi

  # Start new agent
  eval "$(ssh-agent -s)" >/dev/null

  # Add keys
  if [ -f "$HOME/.ssh/id_ed25519" ]; then
    ssh-add "$HOME/.ssh/id_ed25519" 2>/dev/null
  elif [ -f "$HOME/.ssh/id_rsa" ]; then
    ssh-add "$HOME/.ssh/id_rsa" 2>/dev/null
  fi
}

# Create a new directory and cd into it
mkcd() {
  mkdir -p "$1" && cd "$1" || return
}

# Extract various archive formats
extract() {
  if [ -f "$1" ]; then
    case "$1" in
    *.tar.bz2) tar xjf "$1" ;;
    *.tar.gz) tar xzf "$1" ;;
    *.tar.xz) tar xJf "$1" ;;
    *.bz2) bunzip2 "$1" ;;
    *.rar) unrar x "$1" ;;
    *.gz) gunzip "$1" ;;
    *.tar) tar xf "$1" ;;
    *.tbz2) tar xjf "$1" ;;
    *.tgz) tar xzf "$1" ;;
    *.zip) unzip "$1" ;;
    *.Z) uncompress "$1" ;;
    *.7z) 7z x "$1" ;;
    *) echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# Find file by name
ff() {
  if command -v fd &>/dev/null; then
    fd "$1"
  elif command -v fdfind &>/dev/null; then
    fdfind "$1"
  else
    find . -name "*$1*"
  fi
}

# Find and grep in files
fgr() {
  if command -v rg &>/dev/null; then
    rg "$1"
  else
    grep -r "$1" .
  fi
}

# Quick backup of a file
bak() {
  cp "$1" "$1.bak.$(date +%Y%m%d_%H%M%S)"
}

# Get weather
weather() {
  curl -s "wttr.in/${1:-}"
}

# Quick HTTP server
serve() {
  local port="${1:-8000}"
  python3 -m http.server "$port"
}

# Determine platform
detect_platform() {
  local uname_output
  uname_output=$(uname -s)

  local cpu_count cpu_vendor
  if [[ "$uname_output" =~ 'Linux' ]]; then
    export PLATFORM="linux"
    cpu_count=$(nproc)
    cpu_vendor=$(lscpu | grep "Vendor ID:" | awk '{print $NF}')
    export CPU_COUNT="$cpu_count"
    export CPU_VENDOR="$cpu_vendor"
  elif [[ "$uname_output" =~ 'Darwin' ]]; then
    export PLATFORM="macos"
    cpu_count=$(sysctl -n hw.ncpu)
    cpu_vendor=$(sysctl -n machdep.cpu.vendor)
    export CPU_COUNT="$cpu_count"
    export CPU_VENDOR="$cpu_vendor"
  else
    export PLATFORM="unknown"
  fi
}

# Run platform detection
detect_platform

# ----------------------------------------
# System Info Command
# ----------------------------------------
sysi() {
  echo ""
  echo "SYSTEM"
  echo "  Host:      $(hostname) ($(whoami))"
  echo "  OS:        $(grep "^PRETTY_NAME" /etc/os-release 2>/dev/null | cut -d'"' -f2)"
  echo "  Kernel:    $(uname -r)"
  echo "  Uptime:    $(uptime -p 2>/dev/null | sed 's/up //')"
  echo "  Shell:     ${SHELL##*/}"
  echo "  Terminal:  ${TERM}"

  echo ""
  echo "HARDWARE"
  echo "  CPU:       $(grep "model name" /proc/cpuinfo 2>/dev/null | head -1 | cut -d':' -f2 | sed 's/^ //') ($(nproc) cores)"
  echo "  Load:      $(cat /proc/loadavg 2>/dev/null | awk '{print $1, $2, $3}') (1m 5m 15m)"
  echo "  Memory:    $(free -h 2>/dev/null | awk '/^Mem:/{print $3 " / " $2}')"
  if command -v nvidia-smi &>/dev/null; then
    echo "  GPU:       $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)"
    echo "  VRAM:      $(nvidia-smi --query-gpu=memory.used,memory.total --format=csv,noheader 2>/dev/null | head -1 | sed 's/, / \/ /')"
  fi

  echo ""
  echo "STORAGE"
  echo "  Root (/):  $(df -h / 2>/dev/null | awk 'NR==2{print $3 " / " $2 " (" $5 " used)"}')"

  echo ""
  echo "NETWORK"
  echo "  Local IP:  $(hostname -I 2>/dev/null | awk '{print $1}')"
  echo "  Interface: $(ip route get 1 2>/dev/null | awk '{print $5; exit}')"
  local public_ip=$(timeout 1 curl -s icanhazip.com 2>/dev/null)
  [ -n "$public_ip" ] && echo "  Public IP: $public_ip"
  echo "  DNS:       $(grep "^nameserver" /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}')"

  echo ""
  echo "PROCESSES"
  echo "  Total:     $(ps aux 2>/dev/null | wc -l) processes"
  echo "  Running:   $(ps aux 2>/dev/null | awk '$8~/R/{c++}END{print c+0}')"
  echo "  Users:     $(who 2>/dev/null | wc -l) logged in"
  echo "  Top Mem:   $(ps aux --sort=-%mem 2>/dev/null | awk 'NR==2{n=$11; gsub(/.*\//,"",n); printf "%s (%.1f%%)", n, $4}')"
  echo "  Top CPU:   $(ps aux --sort=-%cpu 2>/dev/null | awk 'NR==2{n=$11; gsub(/.*\//,"",n); printf "%s (%.1f%%)", n, $3}')"
  echo ""
}
